# Ethereum Devnet Network Configuration

# Network Parameters
CHAIN_ID=1337
NETWORK_ID=1337

# Consensus Parameters
SECONDS_PER_SLOT=12
SLOTS_PER_EPOCH=6
NUM_VALIDATORS=64

# Timing
GENESIS_DELAY=30

# Ports - Execution Layer
EL_HTTP_PORT=8545      # JSON-RPC HTTP
EL_WS_PORT=8546        # WebSocket
EL_AUTH_PORT=8551      # Engine API (authenticated)
EL_P2P_PORT=30303      # P2P networking

# Ports - Consensus Layer
CL_HTTP_PORT=5052      # Beacon API
CL_P2P_PORT=9000       # P2P networking
CL_METRICS_PORT=5054   # Metrics

# Docker Images
GETH_IMAGE="ethereum/client-go:stable"
LIGHTHOUSE_IMAGE="sigp/lighthouse:latest"
GENESIS_GENERATOR_IMAGE="ethpandaops/ethereum-genesis-generator:master"
ETH2_VAL_TOOLS_IMAGE="protolambda/eth2-val-tools:latest"

# Pre-funded Account (for development)
# Private key: 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# This is a well-known development key - DO NOT use in production
DEV_ACCOUNT="0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266"

# Validator mnemonic for key generation (for development only)
# DO NOT use in production
